# ============================================================
# NobleInvoice Monorepo — .gitignore
# ============================================================

# -----------------------------------------------------------
# ASSET / SAMPLE FOLDERS (not source code)
# -----------------------------------------------------------
Invoice type sample template/
Window/
Mac OS/
*.pdf
NobleInvoice.png

# -----------------------------------------------------------
# NODE / NEXT.JS
# -----------------------------------------------------------
node_modules/
.next/
out/
build/
dist/
.vercel/

# Next.js cache
.cache/
.npm

# Debug/test scripts (not part of the app)
web-app/test-*.mjs
web-app/check-admin.mjs
web-app/extract-pdf.mjs
web-app/update_page.js

# -----------------------------------------------------------
# ENVIRONMENT / SECRETS
# -----------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
secrets.json

# -----------------------------------------------------------
# FLUTTER / DART
# -----------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
Mobile\ App/build/
Mobile\ App/.dart_tool/
**/build/flutter_assets/
**/*.g.dart
**/*.freezed.dart

# -----------------------------------------------------------
# SUPABASE LOCAL DEV
# -----------------------------------------------------------
.supabase/
supabase/.branches/
supabase/.temp/

# -----------------------------------------------------------
# LOGS & OS FILES
# -----------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------
# EDITOR
# -----------------------------------------------------------
.vscode/settings.json
.idea/
*.suo
*.user
*.swp
*.swo
